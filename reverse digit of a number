#include <stdio.h>
int main() {
    int number , reverse = 0, digit;
    
    printf("enter the number;");
    scanf("%d",&number);
    
    int originalNumber = number;
    
    int isNegative = 0;
    if (number < 0)
    {
        isNegative = -number ;
    }
    while (number > 0)
    {
    digit = number % 10;
    reverse = reverse * 10 + digit ;
    number /=10;
    }
    if ( isNegative ){
        reverse = -reverse;
    }
    printf ("reverse of %dis %d\n", originalNumber , reverse );
    
    return 0;
}
